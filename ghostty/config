# By default Reload config with shft + cmd + ,
config-file = ?auto/theme.ghostty
background-opacity = 0.7
background-blur-radius = 50

# font-family = JetBrainsMono Nerd Font
font-family = SF Mono 
# font-family = FiraCode Nerd Font
# font-family = MesloLGS Nerd Font Mono
# font-family = Google Sans Code
font-style = medium
# font-size = 14
font-feature = -liga,-calt,-dlig
cursor-style = block
# cursor-style = underline
cursor-style-blink = false
cursor-color = cell-foreground
cursor-text = cell-background
unfocused-split-opacity = 0.55
split-divider-color = #524f67

macos-window-buttons = hidden
# macos-titlebar-style = hidden
# macos-option-as-alt = true
mouse-hide-while-typing = true

confirm-close-surface = false
window-decoration = auto
window-padding-x = 10
window-padding-y = 10
window-padding-balance = true

auto-update = check
auto-update-channel = stable

# extras
shell-integration-features = no-cursor
copy-on-select = clipboard
# cmd or alt c copy (not vim yank)

# Custom Keybinds & Config (super = cmd key on mac)
# For Simple Keybinds
keybind = ctrl+bracket_left=text:\x1b
keybind = super+i=inspector:toggle
keybind = ctrl+space>[=reload_config

#-------------------------------------------

# Similar to Tmux Panes (no sessions)
# this only works if you have `macos-titlebar-style = tabs or native or transparent` else it behaves like new window
keybind = ctrl+space>c=new_tab
keybind = ctrl+space>n=new_window
keybind = ctrl+space>x=close_surface

# tab nav
keybind = ctrl+space>1=goto_tab:1
keybind = ctrl+space>2=goto_tab:2
keybind = ctrl+space>3=goto_tab:3
keybind = ctrl+space>4=goto_tab:4
keybind = ctrl+space>5=goto_tab:5
keybind = ctrl+space>6=goto_tab:6
keybind = ctrl+space>7=goto_tab:7
keybind = ctrl+space>8=goto_tab:8
keybind = ctrl+space>9=goto_tab:9

# splitting
keybind = ctrl+space>\=new_split:right
keybind = ctrl+space>-=new_split:down
keybind = ctrl+space>e=equalize_splits

# split nav (setting this to control will not work if tmux already uses it)
keybind = ctrl+space>h=goto_split:left
keybind = ctrl+space>j=goto_split:bottom
keybind = ctrl+space>k=goto_split:top
keybind = ctrl+space>l=goto_split:right

